{
  "version": 9,
  "configurePresets": [
    {
      "name": "dev",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/app",
      "installDir": "/tmp/scitt",
      "displayName": "Dev",
      "description": "Dev build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang-18",
        "CMAKE_CXX_COMPILER": "clang++-18",
        "CMAKE_BUILD_WITH_INSTALL_RPATH":"ON",
        "BUILD_TESTS": "ON",
        "ENABLE_CLANG_TIDY": "$env{ENABLE_CLANG_TIDY}"
      },
      "environment": {
        "NINJA_FLAGS": "-k 0",
        "CXXFLAGS": "-ferror-limit=0",
        "GTEST_COLOR": "1",
        "CTEST_OUTPUT_ON_FAILURE": "1",
        "GTEST_CATCH_EXCEPTIONS": "0"
      }
    },
    {
      "name": "bench",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/app",
      "installDir": "/tmp/scitt",
      "displayName": "Bench",
      "description": "Bench build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang-18",
        "CMAKE_CXX_COMPILER": "clang++-18",
        "CMAKE_BUILD_WITH_INSTALL_RPATH":"ON",
        "BUILD_TESTS": "ON",
        "ENABLE_CLANG_TIDY": "$env{ENABLE_CLANG_TIDY}"
      },
      "environment": {
        "CTEST_OUTPUT_ON_FAILURE": "1",
        "GTEST_CATCH_EXCEPTIONS": "0"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "bench",
      "configurePreset": "bench"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "dev",
      "steps": [
        {
          "type": "configure",
          "name": "dev"
        },
        {
          "type": "build",
          "name": "dev"
        },
        {
          "type": "test",
          "name": "dev"
        }
      ]
    },
    {
      "name": "bench",
      "steps": [
        {
          "type": "configure",
          "name": "bench"
        },
        {
          "type": "build",
          "name": "bench"
        }
      ]
    }
  ],
  "vendor": {
    "microsoft.com/VisualStudioSettings/CMake/1.0": {
      "hostOS": "Linux"
    }
  }
}